# Project Zeta .gitignore
# Python Discord bot + future WebUI

# =========================
# Secrets / environment
# =========================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Python packaging / builds
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python tools / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py.cover
.hypothesis/

# Python local database files
*.sqlite
*.sqlite3
db.sqlite3
db.sqlite3-journal

# =========================
# Node / WebUI
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
.next/
out/
dist/
build/
.vite/
.turbo/
.vercel/

# TypeScript / framework cache
*.tsbuildinfo
.eslintcache

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Local data
# =========================
data/*
!data/.gitkeep
*.csv.local
*.json.local

# =========================
# Operating system files
# =========================
.DS_Store
.localized
Thumbs.db
Desktop.ini

# =========================
# Editors / IDEs
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Jupyter / notebooks
# =========================
.ipynb_checkpoints/

# =========================
# Misc
# =========================
.cache/
tmp/
temp/